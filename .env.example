# Leave EVAL_LOOP_BACKEND blank to use Ollama.
EVAL_LOOP_BACKEND=
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_NUM_CTX=4096
OLLAMA_TEMPERATURE=0.2

# Paste your key here when using Claude.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_OUTPUT_TOKENS=4096

EVAL_LOOP_MAX_RUNTIME_SECONDS=300
EVAL_LOOP_MAX_TOTAL_TOKENS=12000
